# uConsole-focused Sway config.
# Mod4 is the Super/Windows key.

set $mod Mod4
set $left h
set $down j
set $up k
set $right l
set $ws1 "1 "
set $ws2 "2 "
set $ws3 "3 "
set $ws4 "4 "
set $ws5 "5 "
set $term /home/mew/.config/sway/terminal.sh
set $menu wofi --show drun --insensitive --matching contains
set $files thunar
set $editor mousepad
set $browser firefox
set $mail thunderbird
set $settings gnome-control-center
set $power_menu /home/mew/.config/sway/power-menu.sh
set $clipboard_menu /home/mew/.config/sway/clipboard-menu.sh
set $gammastep_toggle /home/mew/.config/sway/gammastep-toggle.sh
set $window_menu /home/mew/.config/sway/window-menu.sh
set $wallpaper_menu /home/mew/.config/sway/wallpaper-menu.sh
set $brightness_control /home/mew/.config/sway/brightness.sh
set $theme_menu /home/mew/.config/sway/theme-menu.sh
set $lock /home/mew/.config/sway/lock.sh
set $notifications /home/mew/.config/sway/notifications.sh

include /etc/sway/config-vars.d/*

font pango:Ubuntu Sans 11
floating_modifier $mod normal

default_border pixel 2
default_floating_border pixel 2
hide_edge_borders smart
gaps inner 4
gaps outer 0

client.focused          #2c7a72 #2c7a72 #ffffff #2c7a72 #2c7a72
client.focused_inactive #20252b #20252b #c8d0d4 #20252b #20252b
client.unfocused        #171b20 #171b20 #8b969c #171b20 #171b20
client.urgent           #8f2432 #8f2432 #ffffff #8f2432 #8f2432

### Output
#
# Keep the desktop close to the earlier working size. Foot is configured
# separately below so terminal text starts larger without over-scaling the GUI.
output * scale 1.0
output * scale_filter smart
output * bg "/usr/share/backgrounds/Fuji_san_by_amaral.png" fill

### Input
input type:touchpad {
    tap enabled
    natural_scroll enabled
    dwt enabled
}

input type:keyboard {
    repeat_delay 850
    repeat_rate 10
}

seat * hide_cursor 5000
seat * xcursor_theme Yaru 36

### Session services
exec_always sh -c 'systemctl --user import-environment WAYLAND_DISPLAY SWAYSOCK DISPLAY; dbus-update-activation-environment --systemd WAYLAND_DISPLAY SWAYSOCK DISPLAY XDG_CURRENT_DESKTOP=sway'
exec_always /home/mew/.config/sway/theme-apply.sh
exec_always sh -c 'pgrep -x foot >/dev/null || foot --server'
exec_always sh -c 'pkill waybar 2>/dev/null; waybar'
exec_always sh -c 'if command -v nm-applet >/dev/null && ! pgrep -x nm-applet >/dev/null; then nm-applet --indicator; fi'
exec_always sh -c 'if command -v blueman-applet >/dev/null && ! pgrep -x blueman-applet >/dev/null; then blueman-applet; fi'
exec_always sh -c 'if command -v udiskie >/dev/null && ! pgrep -x udiskie >/dev/null; then udiskie --tray --notify; fi'
exec_always sh -c 'if command -v gammastep >/dev/null && ! pgrep -x gammastep >/dev/null; then gammastep; fi'
exec_always sh -c 'if command -v wl-paste >/dev/null && command -v cliphist >/dev/null && ! pgrep -f "wl-paste --type text --watch cliphist store" >/dev/null; then wl-paste --type text --watch cliphist store & fi'
exec_always sh -c 'if command -v wl-paste >/dev/null && command -v cliphist >/dev/null && ! pgrep -f "wl-paste --type image --watch cliphist store" >/dev/null; then wl-paste --type image --watch cliphist store & fi'
exec_always sh -c 'if command -v swaync >/dev/null; then pkill mako 2>/dev/null; pkill swaync 2>/dev/null; swaync; elif command -v mako >/dev/null && ! pgrep -x mako >/dev/null; then mako; fi'
exec swayidle -w \
    timeout 300 '/home/mew/.config/sway/lock.sh' \
    before-sleep '/home/mew/.config/sway/lock.sh'

### Launchers and session controls
bindsym $mod+Return exec $term
bindsym $mod+space exec $menu
bindsym $mod+d exec $menu
bindsym $mod+Tab exec $window_menu focus
bindsym $mod+Shift+Tab exec $window_menu kill
bindsym $mod+slash exec $term --fullscreen --title=sway-shortcuts sh -lc 'less "$HOME/.config/sway/shortcuts.txt"'
bindsym $mod+Control+l exec $lock
bindsym $mod+Shift+Return exec $term --fullscreen
bindsym $mod+Shift+x exec gnome-system-monitor
bindsym $mod+Escape exec xkill
bindsym $mod+c exec $clipboard_menu
bindsym $mod+n exec $notifications
bindsym $mod+Shift+f exec $files
bindsym $mod+Shift+v exec $editor
bindsym $mod+Shift+b exec $browser
bindsym $mod+Shift+m exec $mail
bindsym $mod+Shift+s exec $settings
bindsym $mod+Shift+n exec nm-connection-editor
bindsym $mod+Shift+a exec pavucontrol
bindsym $mod+Shift+o exec blueman-manager
bindsym $mod+Shift+d exec wdisplays
bindsym $mod+Shift+g exec $gammastep_toggle
bindsym $mod+Shift+t exec $theme_menu
bindsym $mod+Shift+w exec $wallpaper_menu
bindsym $mod+Shift+p exec $power_menu
bindsym $mod+Shift+q kill
bindsym $mod+Shift+c reload
bindsym $mod+Shift+e exec swaynag -t warning -m 'Exit Sway?' -B 'Exit' 'swaymsg exit'
bindsym $mod+Control+Up exec $brightness_control up
bindsym $mod+Control+Down exec $brightness_control down

### Focus and movement
bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

bindsym $mod+Shift+$left move left
bindsym $mod+Shift+$down move down
bindsym $mod+Shift+$up move up
bindsym $mod+Shift+$right move right
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

### Workspaces
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10
bindsym $mod+Control+Tab workspace back_and_forth

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9
bindsym $mod+Shift+0 move container to workspace number 10

### Layout
bindsym $mod+b splith
bindsym $mod+v splitv
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split
bindsym $mod+f fullscreen
bindsym $mod+Shift+space floating toggle
bindsym $mod+Control+space focus mode_toggle
bindsym $mod+a focus parent

### Scratchpad
bindsym $mod+Shift+minus move scratchpad
bindsym $mod+minus scratchpad show

### Screenshots
bindsym Print exec grimshot --notify save screen
bindsym Shift+Print exec grimshot --notify save area
bindsym $mod+Print exec grimshot --notify copy area

### Hardware keys
bindsym XF86AudioRaiseVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
bindsym XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym XF86AudioMicMute exec wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle
bindsym XF86AudioPlay exec playerctl play-pause
bindsym XF86AudioNext exec playerctl next
bindsym XF86AudioPrev exec playerctl previous
bindsym XF86AudioStop exec playerctl stop
bindsym XF86MonBrightnessUp exec $brightness_control up
bindsym XF86MonBrightnessDown exec $brightness_control down

### Resize mode
mode "resize" {
    bindsym $left resize shrink width 10px
    bindsym $down resize grow height 10px
    bindsym $up resize shrink height 10px
    bindsym $right resize grow width 10px
    bindsym Left resize shrink width 10px
    bindsym Down resize grow height 10px
    bindsym Up resize shrink height 10px
    bindsym Right resize grow width 10px
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

### Window rules
for_window [title="sway-shortcuts"] fullscreen enable
for_window [app_id="wdisplays"] floating enable
for_window [app_id="wlogout"] fullscreen enable
for_window [app_id="pavucontrol"] floating enable
for_window [app_id="blueman-manager"] floating enable
for_window [window_role="pop-up"] floating enable

include /etc/sway/config.d/*
